# Public DNS name of your Headscale server.
# Example: vpn.example.com
VPN_DOMAIN=vpn.corp.cz

# Local site subnet that should be reachable over the tailnet.
# Use CIDR notation.
# Example: 192.168.1.0/24
LOCAL_SUBNET=192.168.1.0/24

# Backward-compatible alias for LOCAL_SUBNET.
# If LOCAL_SUBNET is set, it takes precedence.
LAN_SUBNET=192.168.1.0/24

# DNS server that knows your internal AD zone.
# Usually this is your AD DNS server IP.
# Example: 192.168.1.10
AD_DNS_SERVER=192.168.1.1

# Backward-compatible alias for AD_DNS_SERVER.
# If AD_DNS_SERVER is set, it takes precedence.
DNS_SERVER=192.168.1.1

# Internal AD DNS suffix that clients should search.
# Example: corp.local
AD_DOMAIN=corp.local

# Backward-compatible alias for AD_DOMAIN.
# If AD_DOMAIN is set, it takes precedence.
SEARCH_DOMAIN=corp.local

# MagicDNS base domain used inside Headscale.
# This should not collide with your real public domain.
# Example: tailnet.internal
TAILNET_DOMAIN=tailnet.internal

# Email used by Caddy / Let's Encrypt for TLS certificates.
# Example: admin@example.com
ACME_EMAIL=myemail+letsencrypt@example.com

# Headscale user name under which reusable auth keys are created.
# Example: company
HEADSCALE_USER=company

# Dockge web UI port on the host.
# Example: 5001
DOCKGE_PORT=5001

# How Headplane should reach Headscale.
# internal = use Docker network URL http://headscale:8080
# public   = use public URL https://VPN_DOMAIN
# Use public only if the headplane container can reach https://VPN_DOMAIN reliably.
HEADPLANE_HEADSCALE_URL_MODE=internal

# Optional reusable auth key for automatic router login.
# Leave empty if you want install.sh to print the manual tailscale up command instead.
TAILSCALE_AUTH_KEY=

# Optional router node name shown in Headscale/Tailscale.
# Leave empty to use the current host name.
ROUTER_HOSTNAME=

# Optional subnet(s) advertised by the router.
# Leave empty to reuse LOCAL_SUBNET.
# Multiple routes are comma-separated.
# Example: 192.168.1.0/24,10.20.30.0/24
ROUTER_ADVERTISE_ROUTES=

# Optional exit node advertisement.
# false = advertise only subnet routes
# true  = advertise subnet routes and exit node capability
ROUTER_ADVERTISE_EXIT_NODE=false
